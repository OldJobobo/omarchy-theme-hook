#!/usr/bin/env bash

HOOK_DIR="${THPM_HOOK_DIR:-$HOME/.config/omarchy/hooks/theme-set.d}"
THPM_STATE_DIR="${THPM_STATE_DIR:-$HOME/.local/share/thpm}"
THPM_VERSION_FILE="${THPM_VERSION_FILE:-$THPM_STATE_DIR/version}"
THPM_UPDATE_CACHE="${THPM_UPDATE_CACHE:-$THPM_STATE_DIR/update-check}"
THPM_UPDATE_CHECK_INTERVAL="${THPM_UPDATE_CHECK_INTERVAL:-86400}"

dot() {
    dot_char=" "
    case $1 in
        green)
            echo -e "\e[32m$dot_char\e[0m"
            ;;
        yellow)
            echo -e "\033[0;33m$dot_char\e[0m"
            ;;
        red)
            echo -e "\e[31m$dot_char\e[0m"
            exit 1
            ;;
        cyan)
            echo -e "\e[36m$dot_char\e[0m"
            ;;
        muted)
            echo -e "  "
            ;;
    esac
}

open_hooks_dir() {
    if [[ -d "$HOOK_DIR" ]]; then
        xdg-open "$HOOK_DIR" & disown
    fi
}

version_value() {
    local key="$1"
    [[ -f "$THPM_VERSION_FILE" ]] || return 1
    awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' "$THPM_VERSION_FILE"
}

cache_value() {
    local key="$1"
    [[ -f "$THPM_UPDATE_CACHE" ]] || return 1
    awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' "$THPM_UPDATE_CACHE"
}

print_update_notice() {
    echo -e "\n$(dot "yellow")Update available: run thpm update"
}

maybe_show_update_notice() {
    local repo
    local branch
    local installed_commit
    local remote_commit
    local now
    local checked_at
    local status

    [[ "${THPM_UPDATE_CHECK:-1}" != "0" ]] || return 0
    command -v git >/dev/null 2>&1 || return 0

    repo="$(version_value repo)"
    branch="$(version_value branch)"
    installed_commit="$(version_value commit)"
    [[ -n "$repo" && -n "$branch" && -n "$installed_commit" ]] || return 0

    now=$(date +%s)
    checked_at="$(cache_value checked_at)"
    status="$(cache_value status)"
    if [[ "$checked_at" =~ ^[0-9]+$ ]] && (( now - checked_at < THPM_UPDATE_CHECK_INTERVAL )); then
        [[ "$status" == "update_available" ]] && print_update_notice
        return 0
    fi

    remote_commit="$(git ls-remote "$repo" "refs/heads/$branch" 2>/dev/null | awk '{ print $1; exit }')"
    [[ -n "$remote_commit" ]] || return 0

    mkdir -p "$THPM_STATE_DIR"
    if [[ "$remote_commit" != "$installed_commit" ]]; then
        {
            printf 'checked_at=%s\n' "$now"
            printf 'status=update_available\n'
            printf 'remote_commit=%s\n' "$remote_commit"
        } > "$THPM_UPDATE_CACHE"
        print_update_notice
    else
        {
            printf 'checked_at=%s\n' "$now"
            printf 'status=current\n'
            printf 'remote_commit=%s\n' "$remote_commit"
        } > "$THPM_UPDATE_CACHE"
    fi
}

cleanup_zen_theme() {
    local hook

    for hook in "$HOOK_DIR"/*-zen.sh "$HOOK_DIR"/*-zen.sh.sample; do
        [[ -f "$hook" ]] || continue
        bash "$hook" --cleanup >/dev/null 2>&1 || true
        return 0
    done
}

get_hook_list() {
    enabled_hooks=()
    disabled_hooks=()
    if [[ -d "$HOOK_DIR" ]]; then
        for hook in "$HOOK_DIR"/*.sh; do
            [[ -f "$hook" ]] || continue
            hook_name=$(basename "$hook" .sh)
            hook_name=${hook_name#*-}
            enabled_hooks+=("$hook_name")
        done
        for hook in "$HOOK_DIR"/*.sh.sample; do
            [[ -f "$hook" ]] || continue
            hook_name=$(basename "$hook" .sh.sample)
            hook_name=${hook_name#*-}
            disabled_hooks+=("$hook_name")
        done
    fi

    echo -e "\nEnabled Plugins:"
    for hook in "${enabled_hooks[@]}"; do
        echo -e " $(dot "green")$hook"
    done

    echo -e "\nDisabled Plugins:"
    for hook in "${disabled_hooks[@]}"; do
        echo -e " $(dot "red")$hook"
    done
    maybe_show_update_notice
}

enable_hooks() {
    hooks_array=("${@:2}")
    for new_hook in "${hooks_array[@]}"; do
        found=0
        if [[ -d "$HOOK_DIR" ]]; then
            for old_hook in "$HOOK_DIR"/*.sh "$HOOK_DIR"/*.sh.sample; do
                [[ -f "$old_hook" ]] || continue
                hook_name=$(basename "$old_hook")
                hook_name=${hook_name%.sample}
                hook_name=${hook_name%.sh}
                hook_name=${hook_name#*-}
                if [[ "$hook_name" == "$new_hook" ]]; then
                    found=1
                    enabled_hook="${old_hook%.sample}"
                    if [[ "$old_hook" == *.sample ]]; then
                        mv "$old_hook" "$enabled_hook"
                    fi
                    echo -e "$(dot "green")Plugin Enabled: $hook_name \033[90m($enabled_hook)\033[0m"
                    post_enable "$hook_name"
                    echo
                fi
            done
        fi
        if [[ "$found" -eq 0 ]]; then
            echo -e "$(dot "yellow")Plugin not found: $new_hook"
        fi
    done
}

disable_hooks() {
    hooks_array=("${@:2}")
    for new_hook in "${hooks_array[@]}"; do
        found=0
        if [[ -d "$HOOK_DIR" ]]; then
            for old_hook in "$HOOK_DIR"/*.sh "$HOOK_DIR"/*.sh.sample; do
                [[ -f "$old_hook" ]] || continue
                hook_name=$(basename "$old_hook")
                hook_name=${hook_name%.sample}
                hook_name=${hook_name%.sh}
                hook_name=${hook_name#*-}
                if [[ "$hook_name" == "$new_hook" ]]; then
                    found=1
                    disabled_hook="$old_hook"
                    if [[ "$old_hook" != *.sample ]]; then
                        disabled_hook="$old_hook.sample"
                        mv "$old_hook" "$disabled_hook"
                    fi
                    echo -e "$(dot "red")Plugin Disabled: $hook_name \033[90m($disabled_hook)\033[0m"
                    post_disable "$hook_name"
                    echo
                fi
            done
        fi
        if [[ "$found" -eq 0 ]]; then
            echo -e "$(dot "yellow")Plugin not found: $new_hook"
        fi
    done
}

post_enable() {
    case $1 in
        "discord")
            echo -e "$(dot "yellow")Discord themes cannot be automatically enabled/disabled."
            echo -e "$(dot "muted")Please enable in your Discord client's theme settings panel."
        ;;
        "firefox")
            echo -e "$(dot "yellow")Firefox themes cannot be automatically enabled/disabled."
            echo -e "$(dot "muted")Please read the FAQ to disable Firefox theming."
        ;;
        "gtk")
            if command -v gsettings >/dev/null 2>&1; then
                if [ -f "$HOME/.config/omarchy/current/theme/light.mode" ]; then
                    gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3-tmp
                    gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3
                else
                    gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3-tmp-dark
                    gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3-dark
                fi
            fi
        ;;
        "spotify")
            if command -v spicetify >/dev/null 2>&1; then
                spicetify apply
            fi
        ;;
        "steam")
            adwaita_location=$HOME/.local/share/steam-adwaita
            if [[ -x "$adwaita_location/install.py" ]]; then
                cd "$adwaita_location" && ./install.py \
                    --color-theme omarchy \
                    --extras library/hide_whats_new > /dev/null 2>&1
            fi
        ;;
        "vicinae")
            vicinae theme set omarchy > /dev/null 2>&1
        ;;
        "zen")
            echo -e "$(dot "yellow")Zen themes apply on the next Omarchy theme change."
            echo -e "$(dot "muted")Run thpm run to apply it now."
        ;;
        *) return 0 ;;
    esac
}

post_disable() {
    case $1 in
        "discord")
            echo -e "$(dot "yellow")Discord themes cannot be automatically enabled/disabled."
            echo -e "$(dot "muted")Please enable in your Discord client's theme settings panel."
        ;;
        "firefox")
            echo -e "$(dot "yellow")Firefox themes cannot be automatically enabled/disabled."
            echo -e "$(dot "muted")Please read the FAQ to disable Firefox theming."
        ;;
        "gtk")
            if command -v gsettings >/dev/null 2>&1; then
                if [ -f "$HOME/.config/omarchy/current/theme/light.mode" ]; then
                    gsettings set org.gnome.desktop.interface gtk-theme Adwaita
                else
                    gsettings set org.gnome.desktop.interface gtk-theme Adwaita-dark
                fi
            fi
        ;;
        "spotify")
            if command -v spicetify >/dev/null 2>&1; then
                spicetify restore backup apply
            fi
        ;;
        "steam")
            adwaita_location=$HOME/.local/share/steam-adwaita
            if [[ -x "$adwaita_location/install.py" ]]; then
                cd "$adwaita_location" && ./install.py \
                    --uninstall > /dev/null 2>&1
            fi
        ;;
        "vicinae")
            vicinae theme set vicinae-dark > /dev/null 2>&1
        ;;
        "zen")
            cleanup_zen_theme
            echo -e "$(dot "yellow")Removed THPM-managed Zen theme imports."
            echo -e "$(dot "muted")Restart Zen Browser to clear active browser chrome styles."
        ;;
        *) return 0 ;;
    esac
}

th_run() {
    omarchy-hook "theme-set"
}

th_install() {
    curl -fsSL https://raw.githubusercontent.com/OldJobobo/theme-hook-plugin-manager/thpm/install.sh | bash
}

th_uninstall() {
    curl -fsSL https://raw.githubusercontent.com/OldJobobo/theme-hook-plugin-manager/thpm/uninstall.sh | bash
}

th_help() {
    echo -e "Usage: thpm [command] [plugin]"
    echo
    echo -e "Commands:"
    echo -e "$(dot "muted")  help       Show this help message"
    echo -e "$(dot "muted")  enable     Enable a plugin"
    echo -e "$(dot "muted")  disable    Disable a plugin"
    echo -e "$(dot "muted")  list       List all available plugins"
    echo -e "$(dot "muted")  open       Open the plugins directory"
    echo -e "$(dot "muted")  run        Run/execute the theme-set hook"
    echo -e "$(dot "muted")  update     Update thpm"
    echo -e "$(dot "muted")  uninstall  Uninstall thpm"
    maybe_show_update_notice

}

case $1 in
    open) open_hooks_dir ;;
    dir) open_hooks_dir ;;
    o) open_hooks_dir ;;

    list) get_hook_list ;;
    ls) get_hook_list ;;
    l) get_hook_list ;;

    enable) enable_hooks "$@" ;;
    on) enable_hooks "$@" ;;
    e) enable_hooks "$@" ;;

    disable) disable_hooks "$@" ;;
    off) disable_hooks "$@" ;;
    d) disable_hooks "$@" ;;

    update) th_install ;;
    up) th_install ;;

    uninstall) th_uninstall ;;
    remove) th_uninstall ;;
    rm) th_uninstall ;;

    run) th_run ;;
    r) th_run ;;

    help) th_help ;;
    *) th_help; exit 0 ;;
esac
